KAFKA_EXTERNAL_HOST=141.94.47.110

STELLIO_SEARCH_APP_NAME=Search service
STELLIO_SEARCH_DB_DATABASE=stellio_search
STELLIO_SUBSCRIPTION_APP_NAME=Subscription service
STELLIO_SUBSCRIPTION_DB_DATABASE=stellio_subscription

POSTGRES_PASS=stellio_password
POSTGRES_USER=stellio
POSTGRES_DBNAME=${STELLIO_SEARCH_DB_DATABASE},${STELLIO_SUBSCRIPTION_DB_DATABASE}

STELLIO_DOCKER_TAG=2.30.0

APPLICATION_GRAYLOG_HOST=localhost
APPLICATION_GRAYLOG_PORT=12201
APPLICATION_GRAYLOG_SOURCE=stellio

APPLICATION_PAGINATION_LIMIT_MAX=300
SEARCH_PAYLOAD_MAX_BODY_SIZE=51200000
SUBSCRIPTION_STELLIO_URL=https://portail-api-data.montpellier3m.fr
SUBSCRIPTION_ENTITY_SERVICE_URL=http://search-service:8083

APPLICATION_TENANTS_0_ISSUER=no-issuer
APPLICATION_TENANTS_0_NAME=urn:ngsi-ld:tenant:default
APPLICATION_TENANTS_0_DBSCHEMA=3m

# By default, new matching topics are checked every 5 minutes
# Override this value if you need more frequent checks (e.g., in tests scenarios)
SPRING_KAFKA_CONSUMER_PROPERTIES_METADATA_MAX_AGE_MS=300000

ENVIRONMENT=docker

MANAGEMENT_ENDPOINT_PROMETHEUS_ENABLED=true
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,prometheus
MANAGEMENT_METRICS_PF_TAG=Dev

APPLICATION_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Environment variable used by backup script

PLATFORM_KEY=stellio-3m